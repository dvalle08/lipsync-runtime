APP_HOST=0.0.0.0
APP_PORT=8000
JOBS_ROOT=/var/lib/talking-head/gateway/jobs
MUSE_TALK_RESULTS_ROOT=/var/lib/talking-head/musetalk/results
SADTALKER_RESULTS_ROOT=/var/lib/talking-head/sadtalker/results
REDIS_URL=redis://redis:6379/0
QUEUE_KEY=thr:jobs:queue
PROCESSING_KEY=thr:jobs:processing
COMPOSE_PROJECT_NAME=talking-head-local
COMPOSE_FILE=/srv/talking-head-runtime/deploy/compose.runtime.yaml
MUSE_TALK_INTERNAL_URL=http://musetalk-api:8000
SADTALKER_INTERNAL_URL=http://sadtalker-api:8000
BACKEND_START_TIMEOUT_SECONDS=300
BACKEND_IDLE_TIMEOUT_SECONDS=900
QUEUE_POP_TIMEOUT_SECONDS=2
MUSE_TALK_DEFAULT_FPS=25
MUSE_TALK_DEFAULT_USE_CACHE=true
SADTALKER_DEFAULT_SIZE=256
SADTALKER_DEFAULT_PREPROCESS=crop
SADTALKER_DEFAULT_ENHANCER=gfpgan
SADTALKER_DEFAULT_STILL=true
